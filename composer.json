{
    "name": "psychedcms/psychedcms-message-template",
    "description": "Editable, localized message templates for PsychedCMS - reusable across notifications, emails, SMS",
    "type": "symfony-bundle",
    "license": "proprietary",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "php": ">=8.3",
        "psychedcms/psychedcms-core": "^1.0 || @dev",
        "doctrine/orm": "^3.0",
        "symfony/config": "^7.4",
        "symfony/dependency-injection": "^7.4",
        "symfony/http-kernel": "^7.4",
        "symfony/uid": "^7.4",
        "stof/doctrine-extensions-bundle": "^1.12"
    },
    "require-dev": {
        "api-platform/core": "^4.0",
        "phpunit/phpunit": "^11.0"
    },
    "suggest": {
        "api-platform/core": "Required to expose the admin templates CRUD API"
    },
    "autoload": {
        "psr-4": {
            "PsychedCms\\MessageTemplate\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "PsychedCms\\MessageTemplate\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    }
}
